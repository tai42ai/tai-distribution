# ---------------------------------------------------------------------------
# Core TAI compose stack — example environment.
#
#   cp .env.example .env      # then replace every placeholder below.
#
# Compose reads this file automatically (it sits beside docker-compose.yml) for
# ${VAR} substitution. It ships ONLY non-functional placeholders; never commit a
# real `.env` (it is git-ignored). Do not reuse one deployment's secrets in
# another. The datastore hostnames and per-feature connection URLs are wired in
# docker-compose.yml against the compose network — you only set the values here.
# ---------------------------------------------------------------------------

# --- Image / exposure -------------------------------------------------------
# Distribution image tag to run (pin to a release like 0.1.0 in production).
TAI_VERSION=latest
# Host port that serve's HTTP API + Studio SPA is published on.
TAI_SERVE_PORT=8000

# --- Postgres (REQUIRED) ----------------------------------------------------
# One database credential feeds both the postgres container and every
# postgres-backed store (access-control / connector / marketplace / versioning).
# POSTGRES_PASSWORD has no default — the stack refuses to start until it is set.
POSTGRES_USER=tai
POSTGRES_DB=tai
# Generate one with: openssl rand -hex 24
POSTGRES_PASSWORD=

# --- Access control ---------------------------------------------------------
# `false` here is the docs' auth-free QUICKSTART shape: every HTTP route is
# open. For production, set this to `true` (or delete the line — the app's own
# default is on) AND: name an identity provider lifecycle module in
# config/manifest.yml (see the commented block there), then pin your probe
# routes public (`tai scopes public-pin /health`, `... /ready`) and provision
# keys per the access-control guide.
ACCESS_CONTROL_ENABLE=false

# --- Task backend selection -------------------------------------------------
# Which task backend the manifest's `backend_module: !ENV ${TAI_BACKEND_MODULE:...}`
# loads. Leave unset (or tai42_backend_arq) for the Redis-only default; set to
# tai42_backend_celery and run `docker compose --profile celery up -d` for celery.
# tai42_backend_rq is also installed in the image.
TAI_BACKEND_MODULE=tai42_backend_arq

# --- celery profile (RabbitMQ broker) ---------------------------------------
# Only used when TAI_BACKEND_MODULE=tai42_backend_celery. A non-guest user so the
# broker works over the compose network. The celery profile refuses to start
# until RABBITMQ_PASSWORD is set; generate one with: openssl rand -hex 24
RABBITMQ_USER=tai
RABBITMQ_PASSWORD=

# --- minio profile (S3 object storage for tai42_storage_s3) -------------------
# Only used with `--profile minio`. These are also the S3 access-key / secret-key
# the tai42_storage_s3 provider authenticates with. The minio profile refuses to
# start until MINIO_ROOT_PASSWORD is set; generate one with: openssl rand -hex 24
MINIO_ROOT_USER=tai
MINIO_ROOT_PASSWORD=
# Bucket the provider writes to (created by the minio-init one-shot on first up).
STORAGE_S3_BUCKET=tai

# ---------------------------------------------------------------------------
# Optional app config the compose does NOT preset — add as needed. Compose
# injects THIS file's values only for the keys referenced in docker-compose.yml;
# arbitrary app settings go in `config/.env` (bind-mounted at /app and read by
# the app in file config mode). Create it even when empty (`touch config/.env`)
# — the app's config-reload path re-reads it and treats a missing file as an
# error.
#
# LLM provider keys (needed only for agent / LLM-backed tools):
#   OPENAI_API_KEY=sk-changeme
#   ANTHROPIC_API_KEY=sk-ant-changeme
#
# Langfuse tracing (see compose/langfuse/ for the standalone stack, and set
# monitoring_module: tai42_monitoring_langfuse in your manifest):
#   LANGFUSE_HOST=http://localhost:3000
#   LANGFUSE_PUBLIC_KEY=pk-lf-changeme
#   LANGFUSE_SECRET_KEY=sk-lf-changeme
#
# agents-redis profile: point your manifest's langgraph checkpoint/store config
# at the module-capable redis this profile adds:
#   redis://redis-agents:6379
# ---------------------------------------------------------------------------
