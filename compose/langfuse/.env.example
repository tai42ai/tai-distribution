# ---------------------------------------------------------------------------
# Standalone Langfuse v3 stack — example environment.
#
#   cp .env.example .env      # then replace EVERY placeholder below.
#
# This file ships ONLY non-functional placeholders. Never commit a real .env
# (it is git-ignored). Every value marked `generate-with:` or `CHANGE-ME` MUST
# be replaced before `docker compose up` — the stack refuses to start while a
# required secret is unset. Do not reuse one deployment's secrets in another.
# ---------------------------------------------------------------------------

# --- Langfuse app crypto secrets (REQUIRED) --------------------------------
# SALT: any long random string used when hashing API keys.
LANGFUSE_SALT=generate-with: openssl rand -base64 32
# ENCRYPTION_KEY: MUST be exactly 64 hex chars (256-bit). Encrypts secrets at
# rest; changing it after first boot makes existing encrypted data unreadable.
LANGFUSE_ENCRYPTION_KEY=generate-with: openssl rand -hex 32
# NEXTAUTH_SECRET: signs the web session/JWT cookies.
LANGFUSE_NEXTAUTH_SECRET=generate-with: openssl rand -base64 32

# --- Datastore credentials (REQUIRED) --------------------------------------
# Use URL-safe values (letters/digits) — these are interpolated into
# connection URLs. Postgres user/db default to `langfuse`; override if you like.
LANGFUSE_POSTGRES_USER=langfuse
LANGFUSE_POSTGRES_DB=langfuse
LANGFUSE_POSTGRES_PASSWORD=generate-with: openssl rand -hex 24
LANGFUSE_CLICKHOUSE_PASSWORD=generate-with: openssl rand -hex 24
LANGFUSE_REDIS_PASSWORD=generate-with: openssl rand -hex 24
# MinIO object storage — also used as the S3 access-key / secret-key pair that
# Langfuse authenticates its event uploads with.
LANGFUSE_MINIO_ROOT_USER=CHANGE-ME-minio-access-key
LANGFUSE_MINIO_ROOT_PASSWORD=generate-with: openssl rand -hex 24
# Bucket name for Langfuse event uploads (created automatically on first boot).
LANGFUSE_S3_BUCKET=langfuse

# --- Headless bootstrap: first-boot org / project / owner user (REQUIRED) ---
# On first start Langfuse creates this org, project, API key pair, and owner
# user. The PROJECT public/secret keys below are what the TAI app authenticates
# with (see the app-wiring block at the bottom) — keep them in sync.
LANGFUSE_INIT_ORG_ID=tai
LANGFUSE_INIT_ORG_NAME=TAI
LANGFUSE_INIT_PROJECT_ID=tai
LANGFUSE_INIT_PROJECT_NAME=tai
# Langfuse key format is `pk-lf-<uuid>` / `sk-lf-<uuid>`. Generate a unique UUID
# for each (e.g. `python -c "import uuid;print(uuid.uuid4())"`).
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-CHANGE-ME-generate-a-uuid
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-CHANGE-ME-generate-a-uuid
LANGFUSE_INIT_USER_EMAIL=admin@example.com
LANGFUSE_INIT_USER_NAME=TAI Admin
LANGFUSE_INIT_USER_PASSWORD=generate-with: openssl rand -base64 24

# --- Web exposure ----------------------------------------------------------
# Host port for the Langfuse UI/API (bound to 127.0.0.1 in the compose file).
LANGFUSE_WEB_PORT=3000
# Public URL the browser reaches Langfuse at. Behind a reverse proxy / TLS, set
# this to the external https:// origin.
LANGFUSE_NEXTAUTH_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# App-wiring block — connect the TAI app to THIS Langfuse.
#
# These variables are read by the `tai42-monitoring-langfuse` plugin
# (env prefix `LANGFUSE_`, verified in tai42_monitoring_langfuse/settings.py).
# They belong in the CORE compose's .env (compose/.env), NOT in this file, and
# require `monitoring_module: tai42_monitoring_langfuse` in your manifest.yml.
#
#   LANGFUSE_HOST=http://localhost:3000        # = LANGFUSE_NEXTAUTH_URL above
#   LANGFUSE_PUBLIC_KEY=<same value as LANGFUSE_INIT_PROJECT_PUBLIC_KEY above>
#   LANGFUSE_SECRET_KEY=<same value as LANGFUSE_INIT_PROJECT_SECRET_KEY above>
#   LANGFUSE_TRACING_ENVIRONMENT=tai           # optional, defaults to "tai"
#   LANGFUSE_TIMEOUT_SECONDS=30                 # optional, defaults to 30
# ---------------------------------------------------------------------------
